# ─── Supabase Configuration ───
# Get these from: Supabase Dashboard → Settings → API
#
# IMPORTANT: Use the SERVICE_ROLE key here, not the anon key. The service
# role bypasses RLS, which is what we want for a server-side trusted
# environment. The anon key MUST NOT be deployed because RLS policies
# created for the legacy SQL allowed everything (`USING (true)`) — that
# combination would expose every users / payments row to anyone holding
# the key. Re-run the latest setup-*.sql to lock the policies down.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-service-role-key-here

# ─── Server Configuration ───
PORT=3000
NODE_ENV=production

# ─── Google Meet Configuration ───
# Pre-created Google Meet links — each new user is randomly assigned one
# from this pool. Create at https://meet.google.com → "Create a meeting
# for later" and paste the URL exactly as Google gives it.
#
# Format is strictly enforced: https://meet.google.com/xxx-xxxx-xxx
# (lowercase 3-4-3 dashed). Anything else is rejected at boot — in
# production the server refuses to start, in development it just warns.
#
# Pool size: set as many _1, _2, _3, … as you want. Gaps are tolerated
# (e.g. you can have _1 and _3 without _2). MAX_SLOT is 20.
MEET_LINK_1=https://meet.google.com/xxx-yyyy-zzz
MEET_LINK_2=https://meet.google.com/aaa-bbbb-ccc

# ─── WhatsApp Configuration ───
WHATSAPP_NUMBER=919019879108

# ─── Admin Console (admin.html) — username + password login ───
# Used by /admin/login to issue an 8h JWT for the registry UI.
# Required for the admin console. If ADMIN_PASSWORD is unset, ADMIN_KEY
# (kept for backward compatibility) is used as the fallback password.
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-strong-admin-password

# Legacy admin key — formerly used to verify payments directly. As of v1.1
# payment verification routes require an admin JWT instead. Keeping the
# variable around only because it acts as the fallback password if
# ADMIN_PASSWORD is unset. Safe to delete once ADMIN_PASSWORD is set.
ADMIN_KEY=your-secret-admin-key-here

# ─── Google OAuth (SSO) ───
# Required in production; the server will refuse to start if either of
# JWT_SECRET / GOOGLE_CLIENT_ID is missing when NODE_ENV=production.
# Generate JWT_SECRET with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
JWT_SECRET=at-least-32-chars-of-cryptographically-random-bytes

# ─── CORS (your frontend domain) ───
# Comma-separated list of allowed origins, e.g.
#   https://yourusername.github.io,https://yourcustomdomain.com
# When empty in production, all origins are rejected. When empty in
# development, all origins are accepted (with a warning).
FRONTEND_URL=https://yourusername.github.io

# ─── Slack Notifications ───
# Channel-routed business-event alerts. Each event posts to its primary
# channel plus the firehose (SLACK_WEBHOOK_ALL). Any URL left empty
# silently skips that channel — useful in dev so you don't spam your
# team while testing locally.
#
# Create one Slack incoming webhook per channel:
#   https://api.slack.com/apps → your app → Incoming Webhooks
# Paste each webhook URL below. Restart the server to pick up changes.
#
# Channel routing (see backend/slack-notify.js for the full table):
#   ALL                → #all-devtools-pro   firehose, mirrors everything
#   REGISTRATION       → #registartion       new users + first subscriptions
#   RENEW              → #renew_plan         same-plan renewals
#   CHANGE             → #change_plan        upgrades, downgrades, pending applied
#   CANCEL             → #cancel_sub         user or admin-initiated cancellations
#   EXPIRY             → #plan_expiry        payment session timeouts
#   PAYMENTS_PENDING   → #payments_pending   UTR submitted, awaiting verify
#   PAYMENTS_VERIFIED  → #payments_verified  verified (auto or admin)
#   ADMIN              → #admin_audit        admin patch/delete/restore/duplicate-UTR
#   REVIEWS            → #reviews            new user reviews awaiting approval
#   VIP                → #vip (optional)     Pro Max + Power activations only
SLACK_WEBHOOK_ALL=
SLACK_WEBHOOK_REGISTRATION=
SLACK_WEBHOOK_RENEW=
SLACK_WEBHOOK_CHANGE=
SLACK_WEBHOOK_CANCEL=
SLACK_WEBHOOK_EXPIRY=
SLACK_WEBHOOK_PAYMENTS_PENDING=
SLACK_WEBHOOK_PAYMENTS_VERIFIED=
SLACK_WEBHOOK_ADMIN=
SLACK_WEBHOOK_REVIEWS=
SLACK_WEBHOOK_VIP=

# Admin console URL — surfaced as the "Open in Admin" button on every
# Slack alert. Honours ?uid=<userId>. Defaults to the production URL.
ADMIN_URL=https://devtools-proai.github.io/devtoolspro/admin.html
